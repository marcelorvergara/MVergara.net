{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "mvergara-net",
  "compatibility_date": "2026-06-24",
  "observability": {
    "enabled": true
  },
  "main": "./dist/server/server.mjs",
  "assets": {
    "binding": "ASSETS",
    "directory": "dist/browser"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
